    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.16",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  }

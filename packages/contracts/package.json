    "deploy:sepolia:nft": "CONTRACT_NAME=MyFirstNft hardhat run scripts/deploy.ts --network sepolia",
    "clean": "hardhat clean",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
